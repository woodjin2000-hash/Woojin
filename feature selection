def collect_finish_today_results(fs_root_dir: Path) -> pd.DataFrame:
    rows = []

    manifest_path = fs_root_dir / "finish_today_manifest.csv"
    manifest_df = pd.read_csv(manifest_path) if manifest_path.exists() else None

    for exp_dir in sorted([p for p in fs_root_dir.iterdir() if p.is_dir()]):
        lead_dirs = [p for p in exp_dir.iterdir() if p.is_dir() and p.name.startswith("lead_")]
        for lead_dir in lead_dirs:
            lead = int(lead_dir.name.split("_")[1])

            summary_path = lead_dir / "split_grid_distribution_summary.csv"
            grid_path = lead_dir / "grid_metrics_all_splits_hlast.csv"
            overall_path = lead_dir / "overall_metrics_hlast.csv"

            if not (summary_path.exists() and grid_path.exists() and overall_path.exists()):
                continue

            summary_df = pd.read_csv(summary_path)
            grid_df = pd.read_csv(grid_path)
            overall_df = pd.read_csv(overall_path)

            for split_name in ["val", "test"]:
                row = {
                    "experiment": exp_dir.name,
                    "lead": lead,
                    "split": split_name,
                }

                if manifest_df is not None:
                    mm = manifest_df[(manifest_df["experiment"] == exp_dir.name) & (manifest_df["lead"] == lead)]
                    if len(mm) > 0:
                        row["mode"] = mm["mode"].iloc[0]
                        row["n_added_dynamic"] = int(mm["n_added_dynamic"].iloc[0])
                        row["n_added_static"] = int(mm["n_added_static"].iloc[0])
                        row["added_dynamic"] = mm["added_dynamic"].iloc[0]
                        row["added_static"] = mm["added_static"].iloc[0]

                df_r2 = summary_df[(summary_df["split"] == split_name) & (summary_df["metric"] == "r2")]
                if len(df_r2) > 0:
                    row["grid_r2_mean"] = float(df_r2["mean"].iloc[0])
                    row["grid_r2_median"] = float(df_r2["median"].iloc[0])
                    row["grid_r2_q1"] = float(df_r2["q1"].iloc[0])
                    row["grid_r2_q3"] = float(df_r2["q3"].iloc[0])

                df_split = grid_df[grid_df["split"] == split_name].copy()
                if len(df_split) > 0:
                    row["positive_grid_ratio"] = float((df_split["r2"] > 0).mean())

                ov = overall_df[overall_df["split"] == split_name].copy()
                if len(ov) > 0:
                    row["pooled_r2"] = float(ov["pooled_r2"].iloc[0])
                    row["rmse"] = float(ov["rmse"].iloc[0])
                    row["mae"] = float(ov["mae"].iloc[0])

                rows.append(row)

    out = pd.DataFrame(rows)
    if len(out) == 0:
        return out

    return out.sort_values(
        ["lead", "split", "grid_r2_median", "positive_grid_ratio", "pooled_r2"],
        ascending=[True, True, False, False, False]
    ).reset_index(drop=True)


def rank_finish_today_winners(results_df: pd.DataFrame) -> pd.DataFrame:
    if len(results_df) == 0:
        return results_df

    val_df = results_df[results_df["split"] == "val"].copy()

    # tie-break:
    # 1) val grid_r2_median
    # 2) val positive_grid_ratio
    # 3) val pooled_r2
    # 4) fewer added vars
    val_df["n_added_total"] = val_df.get("n_added_dynamic", 0).fillna(0) + val_df.get("n_added_static", 0).fillna(0)

    ranked = val_df.sort_values(
        ["lead", "grid_r2_median", "positive_grid_ratio", "pooled_r2", "n_added_total"],
        ascending=[True, False, False, False, True]
    ).groupby("lead", as_index=False).head(5)

    return ranked.reset_index(drop=True)
