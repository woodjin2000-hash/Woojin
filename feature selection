def _generate_shortlist_combos(lead: int) -> List[Tuple[List[str], List[str]]]:
    info = FS_SHORTLIST_BY_LEAD[int(lead)]
    dyn = list(info["dynamic"])
    sta = list(info["static"])
    max_k = int(info["max_k"])

    items = [("dynamic", v) for v in dyn] + [("static", v) for v in sta]

    combos = []
    if max_k <= 0 or len(items) == 0:
        return combos

    for k in range(1, min(max_k, len(items)) + 1):
        for subset in combinations(items, k):
            add_dyn = [v for kind, v in subset if kind == "dynamic"]
            add_sta = [v for kind, v in subset if kind == "static"]
            combos.append((add_dyn, add_sta))

    return combos


def build_finish_today_fs_plan(
    target_leads: Sequence[int] = (1, 3, 6, 9, 12, 18, 24),
    include_all_features: bool = True,
) -> Tuple[List[Dict], pd.DataFrame]:
    plan = []
    manifest_rows = []

    for lead in target_leads:
        lead = int(lead)
        prefix = f"L{lead:02d}"

        # core
        exp_name = f"{prefix}_000_CORE"
        cfg = _make_fs_cfg_core(CONFIG, lead, exp_name)
        plan.append(cfg)
        manifest_rows.append({
            "experiment": exp_name,
            "lead": lead,
            "mode": "CORE",
            "n_added_dynamic": 0,
            "n_added_static": 0,
            "added_dynamic": "",
            "added_static": "",
        })

        # all-features
        if include_all_features:
            exp_name = f"{prefix}_999_ALL"
            cfg = _make_fs_cfg_all(CONFIG, lead, exp_name)
            plan.append(cfg)
            manifest_rows.append({
                "experiment": exp_name,
                "lead": lead,
                "mode": "ALL_FEATURES",
                "n_added_dynamic": len(FS_ALL_DYNAMIC) - len(FS_CORE_DYNAMIC),
                "n_added_static": len(FS_ALL_STATIC) - len(FS_CORE_STATIC),
                "added_dynamic": ",".join([v for v in FS_ALL_DYNAMIC if v not in FS_CORE_DYNAMIC]),
                "added_static": ",".join([v for v in FS_ALL_STATIC if v not in FS_CORE_STATIC]),
            })

        # shortlisted combos
        combos = _generate_shortlist_combos(lead)
        for idx, (add_dyn, add_sta) in enumerate(combos, start=1):
            exp_name = f"{prefix}_{idx:03d}_SUBSET"
            cfg = _make_fs_cfg_subset(
                CONFIG,
                lead=lead,
                exp_name=exp_name,
                add_dynamic=add_dyn,
                add_static=add_sta,
            )
            plan.append(cfg)
            manifest_rows.append({
                "experiment": exp_name,
                "lead": lead,
                "mode": "SUBSET",
                "n_added_dynamic": len(add_dyn),
                "n_added_static": len(add_sta),
                "added_dynamic": ",".join(add_dyn),
                "added_static": ",".join(add_sta),
            })

    manifest_df = pd.DataFrame(manifest_rows)
    return plan, manifest_df


def validate_finish_today_plan(plan: List[Dict]) -> List[Dict]:
    ds = xr.open_dataset(MERGED_NC_PATH)
    available_vars = set(ds.data_vars.keys()) | set(ds.variables.keys())

    valid_plan = []
    for cfg in plan:
        missing_dyn = [v for v in cfg["dynamic_vars"] if v not in available_vars]
        missing_sta = [
            v for v in cfg["static_vars"]
            if v not in available_vars and v not in ["cell_lat", "cell_lon", "lat", "lon", "latitude", "longitude"]
        ]

        if missing_dyn or missing_sta:
            print(f"[SKIP] {cfg['out_dir']}")
            print(f"  missing dynamic: {missing_dyn}")
            print(f"  missing static : {missing_sta}")
            continue

        valid_plan.append(cfg)

    ds.close()
    return valid_plan



def run_finish_today_fs(
    target_leads: Sequence[int] = (1, 3, 6, 9, 12, 18, 24),
    include_all_features: bool = True,
) -> None:
    plan, manifest_df = build_finish_today_fs_plan(
        target_leads=target_leads,
        include_all_features=include_all_features,
    )
    plan = validate_finish_today_plan(plan)

    fs_root = Path(CONFIG["out_dir"]).parent / "FEATURE_SELECTION" / "finish_today"
    fs_root.mkdir(parents=True, exist_ok=True)
