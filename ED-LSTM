def run_single_lead_experiment(
    ds: xr.Dataset,
    base_cfg: Dict,
    lead: int,
    device: torch.device,
    root_out_dir: Path,
) -> None:
    lead_dir = root_out_dir / f"lead_{lead:02d}"
    lead_dir.mkdir(parents=True, exist_ok=True)

    # 1) selection split
    selection_split = SplitConfig(**base_cfg["selection_split"])
    prepared_sel = prepare_scpdsi_data(
        ds=ds,
        dynamic_vars=base_cfg["dynamic_vars"],
        decoder_future_vars=base_cfg["decoder_future_vars"],
        static_vars=base_cfg["static_vars"],
        append_static_to_encoder=bool(base_cfg["append_static_to_encoder"]),
        allow_short_history=bool(base_cfg["allow_short_history"]),
        encoder_pad_value=float(base_cfg["encoder_pad_value"]),
        target_var=base_cfg["target_var"],
        lookback=int(base_cfg["lookback"]),
        horizon=int(lead),
        split_cfg=selection_split,
        decoder_time_features=bool(base_cfg["decoder_time_features"]),
        scale_dynamic=bool(base_cfg["scale_dynamic"]),
        scale_target=bool(base_cfg["scale_target"]),
        min_target_time=(base_cfg["min_target_time"])
    )

    save_json(prepared_sel.split_window_info, lead_dir / "selection_window_info.json")

    selection_dir = lead_dir / "selection"
    selection_dir.mkdir(parents=True, exist_ok=True)

    model_sel, history_df = fit_model(prepared_sel, base_cfg, device, selection_dir)
    best_epoch = int(history_df.loc[history_df["val_grid_r2_median"].idxmax(), "epoch"])

    save_json({
        "lead": lead,
        "best_epoch": best_epoch,
        "selection_best_val_grid_r2_median": float(history_df["val_grid_r2_median"].max()),
    }, lead_dir / "selection_info.json")

    # selection train/val save
    for split_name, dataset in {"train": prepared_sel.train, "val": prepared_sel.val}.items():
        loader = DataLoader(dataset, batch_size=int(base_cfg["batch_size"]), shuffle=False, num_workers=0)
        pred_pack_scaled = predict_loader(model_sel, loader, device)
        pred_pack = inverse_pred_pack(pred_pack_scaled, prepared_sel)

        grid_df = per_cell_metrics_from_pack(
            pred_pack=pred_pack,
            cell_values=prepared_sel.cell_values,
            cell_lat=prepared_sel.cell_lat,
            cell_lon=prepared_sel.cell_lon,
            hlast_only=True,
        )
        grid_df.insert(0, "split", split_name)
        grid_df.insert(0, "lead", lead)
        grid_df.to_csv(selection_dir / f"{split_name}_grid_metrics_hlast.csv", index=False)

        save_grid_metric_map(
            grid_df, "r2",
            selection_dir / f"map_{split_name}_r2_lead{lead:02d}.png",
            f"selection {split_name} grid-wise R2 (lead={lead})",
        )

    # 2) report split
    report_split = SplitConfig(**base_cfg["report_split"])
    prepared_rep = prepare_scpdsi_data(
        ds=ds,
        dynamic_vars=base_cfg["dynamic_vars"],
        decoder_future_vars=base_cfg["decoder_future_vars"],
        static_vars=base_cfg["static_vars"],
        append_static_to_encoder=bool(base_cfg["append_static_to_encoder"]),
        allow_short_history=bool(base_cfg["allow_short_history"]),
        encoder_pad_value=float(base_cfg["encoder_pad_value"]),
        target_var=base_cfg["target_var"],
        lookback=int(base_cfg["lookback"]),
        horizon=int(lead),
        split_cfg=report_split,
        decoder_time_features=bool(base_cfg["decoder_time_features"]),
        scale_dynamic=bool(base_cfg["scale_dynamic"]),
        scale_target=bool(base_cfg["scale_target"]),
        min_target_time=(base_cfg["min_target_time"])
    )

    save_json(prepared_rep.split_window_info, lead_dir / "report_window_info.json")

    refit_dir = lead_dir / "refit"
    refit_dir.mkdir(parents=True, exist_ok=True)

    model = fit_model_fixed_epochs(
        prepared=prepared_rep,
        cfg=base_cfg,
        device=device,
        out_dir=refit_dir,
        n_epochs=best_epoch,
    )

    # 3) final evaluation
    split_map = {
        "train": prepared_rep.train,
        "val": prepared_rep.val,
        "test": prepared_rep.test,
    }

    overall_rows = []
    all_split_grid_df = []

    for split_name, dataset in split_map.items():
        loader = DataLoader(dataset, batch_size=int(base_cfg["batch_size"]), shuffle=False, num_workers=0)
        pred_pack_scaled = predict_loader(model, loader, device)
        pred_pack = inverse_pred_pack(pred_pack_scaled, prepared_rep)
        torch.save(pred_pack, lead_dir / f"{split_name}_pred_pack_original_scale.pt")

        overall = overall_metrics_from_pack(pred_pack, hlast_only=True)
        overall["split"] = split_name
        overall["lead"] = lead
        overall_rows.append(overall)

        grid_df = per_cell_metrics_from_pack(
            pred_pack=pred_pack,
            cell_values=prepared_rep.cell_values,
            cell_lat=prepared_rep.cell_lat,
            cell_lon=prepared_rep.cell_lon,
            hlast_only=True,
        )
        grid_df.insert(0, "split", split_name)
        grid_df.insert(0, "lead", lead)
        grid_df.to_csv(lead_dir / f"{split_name}_grid_metrics_hlast.csv", index=False)
        all_split_grid_df.append(grid_df)

        if split_name in base_cfg["save_maps_for_splits"]:
            save_grid_metric_map(
                grid_df, "r2",
                lead_dir / f"map_{split_name}_r2_lead{lead:02d}.png",
                f"{split_name} grid-wise R2 (lead={lead})",
            )
            save_grid_metric_map(
                grid_df, "rmse",
                lead_dir / f"map_{split_name}_rmse_lead{lead:02d}.png",
                f"{split_name} grid-wise RMSE (lead={lead})",
            )
            save_grid_metric_map(
                grid_df, "mae",
                lead_dir / f"map_{split_name}_mae_lead{lead:02d}.png",
                f"{split_name} grid-wise MAE (lead={lead})",
            )

    overall_df = pd.DataFrame(overall_rows)
    overall_df.to_csv(lead_dir / "overall_metrics_hlast.csv", index=False)

    grid_all_df = pd.concat(all_split_grid_df, axis=0, ignore_index=True)
    grid_all_df.to_csv(lead_dir / "grid_metrics_all_splits_hlast.csv", index=False)

    # split summaries
    summary_rows = []
    for split_name in ["train", "val", "test"]:
        df_split = grid_all_df[grid_all_df["split"] == split_name].copy()
        for metric in ["r2", "rmse", "mae"]:
            row = summarize_distribution(df_split, metric)
            row.update({"lead": lead, "split": split_name, "metric": metric})
            summary_rows.append(row)
    pd.DataFrame(summary_rows).to_csv(lead_dir / "split_grid_distribution_summary.csv", index=False)

    # baselines
    ridge_w = fit_ridge_target_history(
        train_dataset=prepared_rep.train,
        alpha=float(base_cfg["baseline_ridge_alpha"]),
    )

    baseline_rows = []
    for split_name, dataset in split_map.items():
        pack_persistence = persistence_baseline_pred_pack(dataset)
        df_persistence = evaluate_and_save_baseline_pack(
            pred_pack_scaled=pack_persistence,
            prepared=prepared_rep,
            lead_dir=lead_dir,
            split_name=split_name,
            baseline_name="baseline_persistence",
            lead=lead,
        )

        pack_ridge = ridge_target_history_pred_pack(dataset, ridge_w=ridge_w)
        df_ridge = evaluate_and_save_baseline_pack(
            pred_pack_scaled=pack_ridge,
            prepared=prepared_rep,
            lead_dir=lead_dir,
            split_name=split_name,
            baseline_name="baseline_ridge_target_history",
            lead=lead,
        )

        for baseline_name, df in [
            ("baseline_persistence", df_persistence),
            ("baseline_ridge_target_history", df_ridge),
        ]:
            for metric in ["r2", "rmse", "mae"]:
                row = summarize_distribution(df, metric)
                row.update({
                    "lead": lead,
                    "split": split_name,
                    "baseline": baseline_name,
                    "metric": metric,
                })
                baseline_rows.append(row)

    pd.DataFrame(baseline_rows).to_csv(lead_dir / "baseline_distribution_summary.csv", index=False)


