def save_learning_curve(history_df: pd.DataFrame, out_png: Path) -> None:
    fig, ax = plt.subplots(figsize=(8, 5))
    ax.plot(history_df["epoch"], history_df["train_loss"], label="train_loss")
    ax.plot(history_df["epoch"], history_df["val_loss"], label="val_loss")
    ax.set_xlabel("epoch")
    ax.set_ylabel("loss")
    ax.set_title("Learning curve")
    ax.legend()
    ax.grid(True, alpha=0.3)
    fig.tight_layout()
    fig.savefig(out_png, dpi=180, bbox_inches="tight")
    plt.close(fig)


def save_selection_curve(history_df: pd.DataFrame, out_png: Path) -> None:
    fig, ax = plt.subplots(figsize=(8, 5))
    ax.plot(history_df["epoch"], history_df["val_grid_r2_mean"], marker="o", label="val_grid_r2_mean")
    ax.plot(history_df["epoch"], history_df["val_grid_r2_median"], marker="o", label="val_grid_r2_median")
    ax.set_xlabel("epoch")
    ax.set_ylabel("grid-wise R2")
    ax.set_title("Validation h-last grid-wise R2")
    ax.legend()
    ax.grid(True, alpha=0.3)
    fig.tight_layout()
    fig.savefig(out_png, dpi=180, bbox_inches="tight")
    plt.close(fig)


def save_grid_metric_map(
    df: pd.DataFrame,
    metric_col: str,
    out_png: Path,
    title: str,
) -> None:
    if metric_col == "r2":
        cmap = "RdBu_r"
        vmin, vmax = -1.0, 1.0
    else:
        cmap = "viridis"
        vmin = 0.0
        vmax = np.nanquantile(df[metric_col].to_numpy(), 0.95) if len(df) > 0 else 1.0
        if not np.isfinite(vmax) or vmax <= 0:
            vmax = 1.0

    fig, ax = plt.subplots(figsize=(6, 7))
    sc = ax.scatter(
        df["cell_lon"],
        df["cell_lat"],
        c=df[metric_col],
        cmap=cmap,
        s=260,
        marker="s",
        edgecolor="k",
        linewidth=0.25,
        vmin=vmin,
        vmax=vmax,
    )
    ax.set_xlabel("Longitude")
    ax.set_ylabel("Latitude")
    ax.set_title(title)
    ax.set_aspect("equal")
    ax.grid(True, alpha=0.2)
    cbar = plt.colorbar(sc, ax=ax, shrink=0.85)
    cbar.set_label(metric_col)
    fig.tight_layout()
    fig.savefig(out_png, dpi=180, bbox_inches="tight")
    plt.close(fig)


# 9. MODEL BUILD / FIT

def build_model(prepared: PreparedData, cfg: Dict) -> nn.Module:
    enc_input_size = prepared.train.encoder_x.shape[-1]
    dec_input_size = prepared.train.decoder_x.shape[-1]

    model = EDLSTM(
        enc_input_size=enc_input_size,
        dec_input_size=dec_input_size,
        target_col_idx=prepared.target_col_idx,
        target_mode=str(cfg["target_mode"]),
        hidden_size=int(cfg["hidden_size"]),
        num_layers=int(cfg["num_layers"]),
        lstm_dropout=float(cfg["lstm_dropout"]),
        encoder_input_dropout=float(cfg["encoder_input_dropout"]),
        decoder_input_dropout=float(cfg["decoder_input_dropout"]),
        head_dropout=float(cfg["head_dropout"]),
    )
    return model


def fit_model(
    prepared: PreparedData,
    cfg: Dict,
    device: torch.device,
    out_dir: Path,
) -> Tuple[nn.Module, pd.DataFrame]:
    train_loader = DataLoader(prepared.train, batch_size=int(cfg["batch_size"]), shuffle=True, num_workers=0)
    val_loader = DataLoader(prepared.val, batch_size=int(cfg["batch_size"]), shuffle=False, num_workers=0)

    model = build_model(prepared, cfg).to(device)

    optimizer = torch.optim.Adam(
        model.parameters(),
        lr=float(cfg["lr"]),
        weight_decay=float(cfg["weight_decay"]),
    )
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
        optimizer,
        mode="max",
        factor=float(cfg["scheduler_factor"]),
        patience=int(cfg["scheduler_patience"]),
        min_lr=float(cfg["min_lr"]),
    )

    best_score = -np.inf
    best_state = None
    bad_epochs = 0
    history_rows = []

    for epoch in range(int(cfg["max_epochs"])):
        tf_ratio = teacher_forcing_schedule(
            epoch=epoch,
            max_epochs=int(cfg["max_epochs"]),
            start=float(cfg["tf_start"]),
            end=float(cfg["tf_end"]),
        )

        train_loss = train_one_epoch(
            model=model,
            loader=train_loader,
            optimizer=optimizer,
            device=device,
            teacher_forcing_ratio=tf_ratio,
            loss_mode=str(cfg["loss_mode"]),
            max_grad_norm=float(cfg["max_grad_norm"]),
        )

        val_loss = evaluate_loss(
            model=model,
            loader=val_loader,
            device=device,
            loss_mode=str(cfg["loss_mode"]),
        )

        val_grid = evaluate_split_grid_summary(
            model=model,
            dataset=prepared.val,
            prepared=prepared,
            batch_size=int(cfg["batch_size"]),
            device=device,
        )

        history_rows.append({
            "epoch": epoch + 1,
            "lr": optimizer.param_groups[0]["lr"],
            "teacher_forcing_ratio": tf_ratio,
            "train_loss": train_loss,
            "val_loss": val_loss,
            "val_grid_r2_mean": val_grid["grid_r2_mean"],
            "val_grid_r2_median": val_grid["grid_r2_median"],
            "val_grid_rmse_mean": val_grid["grid_rmse_mean"],
            "val_grid_mae_mean": val_grid["grid_mae_mean"],
        })

        score = val_grid["grid_r2_median"]
        if np.isnan(score):
            score = -np.inf

        scheduler.step(score)

        if best_state is None or score > best_score:
            best_score = score
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
            bad_epochs = 0
        else:
            bad_epochs += 1

        if bad_epochs >= int(cfg["patience"]):
            break

    history_df = pd.DataFrame(history_rows)
    history_df.to_csv(out_dir / "train_history.csv", index=False)
    save_learning_curve(history_df, out_dir / "learning_curve.png")
    save_selection_curve(history_df, out_dir / "selection_curve.png")

    if best_state is None:
        raise RuntimeError("No best model state captured.")

    model.load_state_dict(best_state)
    torch.save(best_state, out_dir / "best_model.pt")
    return model, history_df


def fit_model_fixed_epochs(
    prepared: PreparedData,
    cfg: Dict,
    device: torch.device,
    out_dir: Path,
    n_epochs: int,
) -> nn.Module:
    train_loader = DataLoader(prepared.train, batch_size=int(cfg["batch_size"]), shuffle=True, num_workers=0)

    model = build_model(prepared, cfg).to(device)

    optimizer = torch.optim.Adam(
        model.parameters(),
        lr=float(cfg["lr"]),
        weight_decay=float(cfg["weight_decay"]),
    )

    rows = []
    for epoch in range(int(n_epochs)):
        tf_ratio = teacher_forcing_schedule(
            epoch=epoch,
            max_epochs=max(int(n_epochs), 1),
            start=float(cfg["tf_start"]),
            end=float(cfg["tf_end"]),
        )

        train_loss = train_one_epoch(
            model=model,
            loader=train_loader,
            optimizer=optimizer,
            device=device,
            teacher_forcing_ratio=tf_ratio,
            loss_mode=str(cfg["loss_mode"]),
            max_grad_norm=float(cfg["max_grad_norm"]),
        )

        rows.append({
            "epoch": epoch + 1,
            "teacher_forcing_ratio": tf_ratio,
            "train_loss": train_loss,
        })

    pd.DataFrame(rows).to_csv(out_dir / "refit_train_history.csv", index=False)
    torch.save(model.state_dict(), out_dir / "best_model.pt")
    return model



