def run_all_leads_experiment(cfg: Dict) -> None:
    seed_everything(int(cfg["seed"]))
    device = get_device(cfg["device"])

    root_out_dir = Path(cfg["out_dir"])
    root_out_dir.mkdir(parents=True, exist_ok=True)

    ds = open_and_merge_datasets(cfg["nc_path"], cfg["extra_nc_paths"])
    ds = maybe_add_derived_features(ds, cfg)

    run_cfg_to_save = copy.deepcopy(cfg)
    run_cfg_to_save["device_resolved"] = str(device)
    save_json(run_cfg_to_save, root_out_dir / "run_config.json")

    for lead in cfg["leads"]:
        print(f"\n[INFO] Running lead={lead}")
        run_single_lead_experiment(
            ds=ds,
            base_cfg=cfg,
            lead=int(lead),
            device=device,
            root_out_dir=root_out_dir,
        )

    print("\n[INFO] Finished.")
    print(f"[INFO] Outputs saved to: {root_out_dir}")


